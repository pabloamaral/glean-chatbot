# Copy to .env and fill in values. Do not commit .env.

GLEAN_INSTANCE=support-lab
GLEAN_DATASOURCE=interviewds

# Indexing API (used by app/indexer.py)
GLEAN_INDEXING_TOKEN=

# Client API — Search + Chat (used by app/search.py, app/chat.py, app/mcp_tool.py)
GLEAN_CLIENT_TOKEN=

# Optional: user email for X-Glean-ActAs (sandbox default in code: alex@glean-sandbox.com)
# GLEAN_ACT_AS_EMAIL=
