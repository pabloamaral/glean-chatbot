# Copy to .env and fill in values from your Glean sandbox / admin console.
# Never commit .env.

GLEAN_INSTANCE=support-lab
GLEAN_DATASOURCE=interviewds

# Client API: used for Search + Chat (app/search.py, app/chat.py, app/mcp_tool.py)
GLEAN_CLIENT_TOKEN=

# Indexing API: used only by app/indexer.py
GLEAN_INDEXING_TOKEN=

# Optional. Defaults to alex@glean-sandbox.com if unset (see app/config.py).
# GLEAN_ACT_AS_EMAIL=
